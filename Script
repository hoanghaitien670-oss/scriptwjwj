local Players = game:GetService("Players")
local player = Players.LocalPlayer

-- ScreenGui
local gui = Instance.new("ScreenGui")
gui.Name = "InfoUI"
gui.ResetOnSpawn = false
gui.Parent = player:WaitForChild("PlayerGui")

-- Khung chính
local frame = Instance.new("Frame")
frame.Size = UDim2.new(0, 220, 0, 80) -- nhỏ gọn
frame.Position = UDim2.new(0.5, -110, 0, 5) -- sát phía trên màn hình
frame.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
frame.BorderColor3 = Color3.fromRGB(255, 255, 255)
frame.BorderSizePixel = 2
frame.Parent = gui

-- Tên
local nameLabel = Instance.new("TextLabel")
nameLabel.Size = UDim2.new(1, -10, 0, 25)
nameLabel.Position = UDim2.new(0, 5, 0, 0)
nameLabel.BackgroundTransparency = 1
nameLabel.TextColor3 = Color3.fromRGB(255, 215, 0)
nameLabel.TextScaled = true
nameLabel.Font = Enum.Font.GothamBold
nameLabel.TextXAlignment = Enum.TextXAlignment.Left
nameLabel.Text = "Tên: dhai*****"
nameLabel.Parent = frame

-- Đơn
local unitLabel = Instance.new("TextLabel")
unitLabel.Size = UDim2.new(1, -10, 0, 25)
unitLabel.Position = UDim2.new(0, 5, 0, 25)
unitLabel.BackgroundTransparency = 1
unitLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
unitLabel.TextScaled = true
unitLabel.Font = Enum.Font.GothamBold
unitLabel.TextXAlignment = Enum.TextXAlignment.Left
unitLabel.Text = "Đơn: 1-2650"
unitLabel.Parent = frame

-- Ghi chú
local noteLabel = Instance.new("TextLabel")
noteLabel.Size = UDim2.new(1, -10, 0, 25)
noteLabel.Position = UDim2.new(0, 5, 0, 50)
noteLabel.BackgroundTransparency = 1
noteLabel.TextColor3 = Color3.fromRGB(0, 255, 255)
noteLabel.TextScaled = true
noteLabel.Font = Enum.Font.GothamBold
noteLabel.TextXAlignment = Enum.TextXAlignment.Left
noteLabel.Text = "Ghi chú: không có ghi chú"
noteLabel.Parent = frame

-- Hàm đổi nội dung
local function UpdateInfo(name, unit, note)
	nameLabel.Text = "Tên: " .. tostring(name)
	unitLabel.Text = "Đơn: " .. tostring(unit)
	noteLabel.Text = "Ghi chú: " .. tostring(note)
end

-- Ví dụ sử dụng
UpdateInfo("dhai*****", "1-2650", "không có ghi chú")
